APP_ENV=local
APP_KEY=
APP_URL=http://localhost:8000
APP_TIMEZONE=Asia/Kolkata

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=map_hms
DB_USERNAME=postgres
DB_PASSWORD=

REDIS_HOST=127.0.0.1
REDIS_PORT=6379

FILES_S3_DRIVER=minio
FILES_S3_BUCKET=map-hms-dev
FILES_S3_REGION=ap-south-1
FILES_S3_ENDPOINT=http://127.0.0.1:9000
FILES_S3_KEY=minio
FILES_S3_SECRET=minio123
S3_PRESIGN_EXPIRES=900

AVSCAN_HOST=127.0.0.1
AVSCAN_PORT=3310

MSG91_API_KEY=dev
MSG91_SENDER=MAPHST
SENDGRID_API_KEY=dev

# OTP login: SMS OTP is always sent when requested. Bypass is optional for testing/support.
# Set OTP_BYPASS_ENABLED=true to allow a fixed code (OTP_BYPASS_CODE) instead of SMS OTP.
# For E2E/CI: set OTP_AUTOMATION_SECRET and send X-Automation-Secret header + OTP_AUTOMATION_CODE as OTP.
OTP_BYPASS_ENABLED=false
OTP_BYPASS_CODE=123456
OTP_AUTOMATION_SECRET=
OTP_AUTOMATION_CODE=000000

# Push notifications (FCM). Service account file is at storage/app/firebase-service-account.json (gitignored).
# Copy this block to .env and set FCM_SERVICE_ACCOUNT_PATH to the full path to that file on your machine.
FCM_ENABLED=true
FCM_PROJECT_ID=map-hms-29dd1
# Full path to the service account JSON file (e.g. C:\...\mapmars\api\storage\app\firebase-service-account.json)
FCM_SERVICE_ACCOUNT_PATH=
# Option A alternative: paste entire JSON as one line (no FCM_SERVICE_ACCOUNT_PATH needed)
FCM_SERVICE_ACCOUNT_JSON=
# Option B: Legacy server key (only if not using service account)
FCM_SERVER_KEY=

RAZORPAY_KEY_ID=dev
RAZORPAY_KEY_SECRET=dev
RAZORPAY_WEBHOOK_SECRET=dev

SENTRY_LARAVEL_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.2

# CloudWatch Logs Configuration
LOG_CHANNEL=stack
AWS_REGION=ap-south-1
CW_LOG_GROUP=map-hms-api
CW_LOG_STREAM=api-default
GIT_SHA=
CW_METRICS_NAMESPACE=MAP-HMS

# Observability & Monitoring
SENTRY_LARAVEL_DSN=https://your-sentry-dsn@sentry.io/project-id
SENTRY_TRACES_SAMPLE_RATE=0.2
SENTRY_ENVIRONMENT=production

LOG_CHANNEL=stack
LOG_LEVEL=info
CW_LOG_GROUP=map-hms-api
CW_LOG_STREAM=api-default

# Horizon Queue Monitoring
HORIZON_MEMORY=128
HORIZON_TIMEOUT=60

# Alert Thresholds
ALERT_QUEUE_SIZE_THRESHOLD=100
ALERT_TENANT_ISOLATION_FAILURES=true
ALERT_PAYMENT_SYNC_FAILURES=true

# Performance Monitoring
PERFORMANCE_API_RESPONSE_TIME_THRESHOLD=500
PERFORMANCE_DB_QUERY_TIME_THRESHOLD=100

