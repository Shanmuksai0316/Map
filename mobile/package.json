  "private": true,
  "scripts": {
    "android": "react-native run-android",
    "android:student": "react-native run-android --variant=studentDebug",
    "android:staff": "cd android && ./gradlew assembleStaffDebug && cd .. && npx react-native run-android --appIdSuffix=staff",
    "ios": "react-native run-ios",
    "ios:external": "DERIVED_DATA_PATH='/Volumes/Parag SSD/iOS-DerivedData' xcodebuild -workspace ios/rn082template.xcworkspace -scheme rn082template -configuration Debug -sdk iphonesimulator -derivedDataPath '/Volumes/Parag SSD/iOS-DerivedData/DerivedData' -destination 'platform=iOS Simulator,name=iPad Pro 13-inch (M4)' build",
    "test:ios": "./run-student-ios-test.sh",
    "lint": "eslint .",
    "start": "react-native start",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:validation": "jest --testPathPattern=validation",
    "test:errorHandler": "jest --testPathPattern=errorHandler",
    "test:performance": "jest --testPathPattern=performance",
    "test:forms": "jest --testPathPattern=__tests__.*FormScreen"
  },
